package com.edutracker.backend.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

import com.edutracker.backend.model.User;
import com.edutracker.backend.repository.UserRepository;

@RestController
@RequestMapping("/api/fa")
@CrossOrigin(origins = "*")
public class FAController {

    @Autowired
    private UserRepository userRepository;

    @GetMapping("/students/{faEmail}")
    public List<User> getStudents(@PathVariable String faEmail) {

        return userRepository.findByFaEmail(faEmail);

    }
}
